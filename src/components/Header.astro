---
import site from '../data/site.json';
import Logo from './Logo.astro';
import Icon from './Icon.astro';
---

<header class="header">
  <div class="container header__inner">
    <Logo />
    <div class="header__actions">
      <div class="header__phones">
        <a class="phone-link header__phone" href={site.phoneHref}>
          <Icon name="phone" size={18} />
          {site.phone}
        </a>
        <a class="phone-link header__phone" href={site.phoneHref2}>
          <Icon name="phone" size={18} />
          {site.phone2}
        </a>
      </div>
      <a class="btn btn--primary header__cta" href={site.phoneHref}>{site.headerCta}</a>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: #fff;
    border-bottom: 1px solid var(--color-border);
    transition: box-shadow 0.3s var(--ease);
  }

  .header.is-scrolled {
    box-shadow: 0 6px 24px rgba(20, 23, 26, 0.07);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 76px;
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 28px;
    min-width: 0;
  }

  .header__phones {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .header__phone {
    font-size: 15px;
  }

  @media (max-width: 720px) {
    .header__cta {
      display: none;
    }
    .header__phone {
      font-size: 13.5px;
      gap: 7px;
    }
    .header__inner {
      min-height: 64px;
    }
  }
</style>
