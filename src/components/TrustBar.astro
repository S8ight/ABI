---
import site from '../data/site.json';
import Icon from './Icon.astro';
---

<section class="container trustbar-wrap" aria-label="Наші переваги">
  <ul class="trustbar">
    {site.trustBar.map((item, i) => (
      <li class="trustbar__item" data-reveal style={`--reveal-delay:${i * 90}ms`}>
        <span class="trustbar__icon"><Icon name={item.icon} size={24} /></span>
        <span class="trustbar__text">{item.text}</span>
      </li>
    ))}
  </ul>
</section>

<style>
  .trustbar-wrap {
    margin-top: -52px;
    position: relative;
    z-index: 2;
  }

  .trustbar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    padding: 24px 20px;
  }

  .trustbar__item {
    display: flex;
    align-items: center;
    gap: 14px;
    font-weight: 600;
    font-size: 15px;
    padding-inline: 12px;
  }

  .trustbar__item:not(:last-child) {
    border-right: 1px solid var(--color-border);
  }

  .trustbar__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: rgba(47, 93, 58, 0.1);
    color: var(--color-green);
    flex-shrink: 0;
    transition: background-color 0.25s var(--ease), color 0.25s var(--ease),
      transform 0.25s var(--ease);
  }

  .trustbar__item:hover .trustbar__icon {
    background: var(--color-green);
    color: #fff;
    transform: scale(1.08);
  }

  @media (max-width: 900px) {
    .trustbar-wrap {
      margin-top: -36px;
    }
    .trustbar {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px 12px;
    }
    .trustbar__item:nth-child(2n) {
      border-right: none;
    }
  }

  @media (max-width: 520px) {
    .trustbar {
      grid-template-columns: 1fr;
      padding: 18px;
    }
    .trustbar__item {
      border-right: none !important;
    }
  }
</style>
