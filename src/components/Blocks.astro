---
import blocks from '../data/blocks.json';
import RoadStrip from './RoadStrip.astro';
---

<section class="section" id="blocks">
  <div class="container">
    <h2 class="section-title section-title--left" data-reveal>{blocks.heading}</h2>
    <div class="blocks">
      {blocks.items.map((item, i) => (
        <article class="block-card" data-reveal style={`--reveal-delay:${i * 90}ms`}>
          <div class="block-card__media">
            <img src={item.image} alt={item.imageAlt} width="320" height="200" loading="lazy" />
          </div>
          <h3 class="block-card__title">{item.title}</h3>
          <p class="block-card__text">{item.text}</p>
          <dl class="block-card__specs">
            {item.specs.map((s) => (
              <div class="spec">
                <dt>{s.label}</dt>
                <dd>{s.value}</dd>
              </div>
            ))}
          </dl>
        </article>
      ))}
    </div>
  </div>
  <RoadStrip />
</section>

<style>
  #blocks {
    padding-bottom: 0;
  }

  .blocks {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .block-card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 22px;
    transition: transform 0.35s var(--ease), box-shadow 0.35s var(--ease),
      border-color 0.35s var(--ease), background-color 0.35s var(--ease);
  }

  .block-card:hover {
    transform: translateY(-8px);
    background: #fff;
    border-color: transparent;
    box-shadow: var(--shadow-card-hover);
  }

  .block-card__media {
    aspect-ratio: 16 / 10;
    border-radius: var(--radius);
    overflow: hidden;
    background: #fff;
    border: 1px solid var(--color-border);
    margin-bottom: 18px;
  }

  .block-card__media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 10px;
    transition: transform 0.5s var(--ease);
  }

  .block-card:hover .block-card__media img {
    transform: scale(1.06);
  }

  .block-card__title {
    font-size: 17px;
    font-weight: 800;
    letter-spacing: -0.01em;
    line-height: 1.3;
    margin-bottom: 10px;
  }

  .block-card__text {
    color: var(--color-text-muted);
    font-size: 13.5px;
    font-weight: 500;
    line-height: 1.55;
    margin-bottom: 18px;
  }

  .block-card__specs {
    display: flex;
    flex-direction: column;
    margin-top: auto;
  }

  .block-card__specs .spec {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 10px;
    padding: 8px 0;
    border-top: 1px solid var(--color-border);
    font-size: 13px;
  }

  .block-card:hover .block-card__specs .spec {
    border-color: #eceef0;
  }

  .block-card__specs dt {
    color: var(--color-text-muted);
    font-weight: 600;
    flex-shrink: 0;
  }

  .block-card__specs dd {
    color: var(--color-heading);
    font-weight: 700;
    text-align: right;
  }

  @media (max-width: 1080px) {
    .blocks {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .blocks {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin-inline: auto;
    }
  }
</style>
