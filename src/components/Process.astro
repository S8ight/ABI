---
import process from '../data/process.json';
import Icon from './Icon.astro';
---

<section class="section section--alt" id="process">
  <div class="container">
    <h2 class="section-title section-title--left" data-reveal>{process.heading}</h2>
    <ol class="process">
      {process.items.map((item, i) => (
        <li class="step" data-reveal style={`--reveal-delay:${i * 110}ms`}>
          <div class="step__num">
            <span>{item.step}</span>
          </div>
          <span class="step__icon"><Icon name={item.icon} size={26} /></span>
          <h3 class="step__title">{item.title}</h3>
          <p class="step__text">{item.text}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .process {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }

  .step {
    position: relative;
    text-align: center;
    padding-inline: 8px;
  }

  .step:not(:last-child)::after {
    content: '';
    position: absolute;
    top: 29px;
    left: calc(50% + 36px);
    right: calc(-50% + 36px);
    border-top: 2px dashed #bcc2c5;
  }

  .step__num {
    position: relative;
    z-index: 1;
    width: 58px;
    height: 58px;
    margin: 0 auto 18px;
    border-radius: 50%;
    background: #fff;
    border: 2px solid var(--color-green);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-green);
    font-weight: 800;
    font-size: 21px;
    transition: background-color 0.3s var(--ease), color 0.3s var(--ease),
      transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
  }

  .step:hover .step__num {
    background: var(--color-green);
    color: #fff;
    transform: scale(1.08);
    box-shadow: 0 10px 22px rgba(47, 93, 58, 0.3);
  }

  .step__icon {
    display: inline-flex;
    color: var(--color-orange);
    margin-bottom: 12px;
    transition: transform 0.3s var(--ease);
  }

  .step:hover .step__icon {
    transform: translateY(-3px) scale(1.05);
  }

  .step__title {
    font-size: 16.5px;
    font-weight: 800;
    letter-spacing: -0.01em;
    margin-bottom: 8px;
  }

  .step__text {
    color: var(--color-text-muted);
    font-size: 13.5px;
    font-weight: 500;
    line-height: 1.55;
  }

  @media (max-width: 900px) {
    .process {
      grid-template-columns: repeat(2, 1fr);
      gap: 36px 16px;
    }
    .step:not(:last-child)::after {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .process {
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .step {
      display: grid;
      grid-template-columns: auto 1fr;
      column-gap: 18px;
      align-items: center;
      text-align: left;
      padding: 0 0 26px;
      position: relative;
    }
    .step:last-child {
      padding-bottom: 0;
    }
    .step__num {
      grid-column: 1;
      grid-row: 1;
      margin: 0;
    }
    .step__icon {
      display: none;
    }
    .step__title {
      grid-column: 2;
      grid-row: 1;
      margin-bottom: 0;
    }
    .step__text {
      grid-column: 2;
      grid-row: 2;
      margin-top: 6px;
    }
    .step:not(:last-child)::after {
      display: block;
      top: 64px;
      bottom: 0;
      left: 28px;
      right: auto;
      width: 0;
      border-top: none;
      border-left: 2px dashed #c2c7ca;
    }
  }
</style>
