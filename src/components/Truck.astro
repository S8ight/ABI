<style>
  .truck {
    display: block;
    width: 100%;
    height: auto;
  }

  .truck .wheel {
    transform-box: fill-box;
    transform-origin: center;
    animation: truck-wheel 0.9s linear infinite;
  }

  @keyframes truck-wheel {
    to {
      transform: rotate(360deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .truck .wheel {
      animation: none;
    }
  }
</style>
