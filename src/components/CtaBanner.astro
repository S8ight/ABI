---
import site from '../data/site.json';
import Icon from './Icon.astro';
const { cta } = site;
---

<section class="cta-section">
  <div class="container">
    <div class="cta" data-reveal>
      <h2 class="cta__title">{cta.title}</h2>
      <div class="cta__contact">
        <a class="cta__phone" href={site.phoneHref}>
          <Icon name="phone" size={26} />
          {site.phone}
        </a>
        <span class="cta__region">{site.region}</span>
      </div>
      <a class="btn btn--primary btn--lg cta__btn" href={site.phoneHref}>
        {cta.buttonLabel}
        <Icon name="arrow-right" size={18} class="btn__arrow" />
      </a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding-block: 40px 64px;
  }

  .cta {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
    background: var(--color-green);
    color: #fff;
    border-radius: var(--radius-xl);
    padding: 48px 56px;
    overflow: hidden;
  }

  .cta::before,
  .cta::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }
  .cta::before {
    top: -90px;
    right: -60px;
    width: 320px;
    height: 320px;
    background: radial-gradient(circle, rgba(229, 97, 30, 0.22), transparent 65%);
  }
  .cta::after {
    bottom: -120px;
    left: 20%;
    width: 280px;
    height: 280px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.08), transparent 65%);
  }

  .cta__title {
    position: relative;
    color: #fff;
    font-size: clamp(21px, 2.4vw, 29px);
    font-weight: 800;
    letter-spacing: -0.01em;
    line-height: 1.25;
    max-width: 430px;
    flex: 1 1 280px;
  }

  .cta__contact {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: center;
  }

  .cta__phone {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: clamp(25px, 3vw, 35px);
    font-weight: 800;
    letter-spacing: -0.01em;
    transition: transform 0.25s var(--ease);
  }

  .cta__phone:hover {
    transform: scale(1.03);
  }

  .cta__phone svg {
    color: var(--color-orange);
  }

  .cta__region {
    font-size: 14px;
    font-weight: 500;
    opacity: 0.85;
  }

  .cta__btn {
    position: relative;
  }

  @media (max-width: 820px) {
    .cta {
      flex-direction: column;
      text-align: center;
      padding: 34px 24px;
      gap: 22px;
    }
    .cta__title {
      max-width: none;
      flex: none;
    }
  }

  @media (max-width: 480px) {
    .cta {
      padding: 26px 20px;
      gap: 16px;
    }
    .cta__title {
      font-size: 20px;
    }
  }
</style>
