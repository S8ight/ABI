---
import projects from '../data/projects.json';
---

<section class="section section--alt" id="projects">
  <div class="container">
    <header class="projects-head" data-reveal>
      <h2 class="section-title section-title--left">{projects.heading}</h2>
      <p class="projects-subtitle">{projects.subheading}</p>
    </header>

    <div class="projects">
      {projects.items.map((item, i) => (
        <article class="project-card" data-reveal style={`--reveal-delay:${i * 90}ms`}>
          <div class="project-card__media">
            <img src={item.image} alt={item.imageAlt} width="1000" height="563" loading="lazy" />
          </div>
          <div class="project-card__body">
            <h3 class="project-card__title">{item.title}</h3>
            <div class="project-card__meta">
              <span>{item.area}</span>
              <span class="project-card__dot"></span>
              <span>{item.term}</span>
            </div>
            <p class="project-card__detail">{item.detail}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects-head {
    margin-bottom: 40px;
  }

  .projects-head .section-title {
    margin-bottom: 14px;
  }

  .projects-subtitle {
    color: var(--color-text-muted);
    font-size: 16px;
    font-weight: 500;
    line-height: 1.5;
    max-width: 560px;
  }

  .projects {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: transform 0.35s var(--ease), box-shadow 0.35s var(--ease);
  }

  .project-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-card-hover);
  }

  .project-card__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .project-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
  }

  .project-card:hover .project-card__media img {
    transform: scale(1.06);
  }

  .project-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 22px 24px 24px;
  }

  .project-card__title {
    font-size: 20px;
    font-weight: 800;
    letter-spacing: -0.01em;
    margin-bottom: 12px;
  }

  .project-card__meta {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--color-green);
    font-size: 14px;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .project-card__dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-orange);
    flex-shrink: 0;
  }

  .project-card__detail {
    color: var(--color-text-muted);
    font-size: 14.5px;
    font-weight: 500;
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .projects {
      grid-template-columns: repeat(2, 1fr);
      gap: 22px;
    }
  }

  @media (max-width: 560px) {
    .projects {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin-inline: auto;
    }
  }
</style>
