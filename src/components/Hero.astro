---
import site from '../data/site.json';
import Icon from './Icon.astro';
const { hero } = site;
---

<section class="hero">
  <div class="hero__bg" aria-hidden="true">
    <img src={hero.image} alt="" width="1600" height="900" loading="eager" fetchpriority="high" decoding="async" />
  </div>

  <div class="container hero__inner">
    <div class="hero__content">
      <h1 class="hero__title">
        {hero.titleLines.map((line, i) => (
          <span
            class={`hero__line hero__line--${line.color}`}
            data-reveal
            style={`--reveal-delay:${i * 90}ms`}
          >{line.text}</span>
        ))}
        <span class="sr-only"> в межах Івано-Франківської області</span>
      </h1>

      <ul class="hero__bullets" data-reveal style="--reveal-delay:300ms">
        {hero.bullets.map((b) => (
          <li>
            <a class="hero__bullet" href={b.href}>
              <span class="hero__bullet-icon"><Icon name={b.icon} size={20} /></span>
              {b.text}
            </a>
          </li>
        ))}
      </ul>

      <div class="hero__actions" data-reveal style="--reveal-delay:430ms">
        <a class="btn btn--primary btn--lg" href={site.phoneHref}>
          {hero.primaryCta}
          <Icon name="arrow-right" size={18} class="btn__arrow" />
        </a>
        <div class="hero__phones">
          <a class="phone-link hero__phone" href={site.phoneHref}>
            <Icon name="phone" size={20} />
            {site.phone}
          </a>
          <a class="phone-link hero__phone" href={site.phoneHref2}>
            <Icon name="phone" size={20} />
            {site.phone2}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: clamp(560px, 82vh, 780px);
    overflow: hidden;
    background: #0f141b;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
    filter: brightness(1.22);
    transform: scale(1.1) translateX(4%);
    transform-origin: center bottom;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      100deg,
      rgba(15, 20, 27, 0.92) 0%,
      rgba(15, 20, 27, 0.8) 32%,
      rgba(15, 20, 27, 0.42) 56%,
      rgba(15, 20, 27, 0.08) 80%,
      rgba(15, 20, 27, 0) 100%
    );
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    padding-block: 64px;
  }

  .hero__content {
    max-width: 600px;
  }

  .hero__title {
    font-size: clamp(40px, 5.4vw, 70px);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 0.98;
    margin-bottom: 30px;
    color: #fff;
  }

  .hero__line {
    display: block;
  }
  .hero__line--dark {
    color: #fff;
  }
  .hero__line--orange {
    color: var(--color-orange);
  }
  .hero__line--green {
    color: #7cc070;
  }

  .hero__bullets {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 38px;
  }

  .hero__bullet {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-size: 17px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.92);
    transition: transform 0.25s var(--ease);
  }

  .hero__bullet:hover {
    transform: translateX(4px);
  }

  .hero__bullet-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    flex-shrink: 0;
    backdrop-filter: blur(2px);
    transition: background-color 0.25s var(--ease), transform 0.25s var(--ease);
  }

  .hero__bullet:hover .hero__bullet-icon {
    background: var(--color-orange);
    transform: scale(1.06);
  }

  .hero__actions {
    display: flex;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
  }

  .hero__phones {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .hero__phone {
    color: #fff;
  }

  @media (max-width: 768px) {
    .hero::after {
      background: linear-gradient(
        100deg,
        rgba(15, 20, 27, 0.95) 0%,
        rgba(15, 20, 27, 0.85) 55%,
        rgba(15, 20, 27, 0.7) 100%
      );
    }
    .hero__content {
      max-width: none;
    }
  }

  @media (max-width: 540px) {
    .hero {
      min-height: 540px;
    }
    .hero__inner {
      padding-block: 48px;
    }
  }
</style>
